# =============================================================================
# NovaSafe Landing (novasafe.io) — environment template
# =============================================================================
#
# HOW TO USE
#   1. Copy this file:  cp .env.example .env
#   2. Fill in any values you want to override.
#   3. Start the dev server: pnpm dev
#
# RULES
#   - Never commit `.env` (real secrets). Only commit `.env.example`.
#   - Variables prefixed with VITE_ are exposed to the browser bundle.
#   - Production: copy values to the VPS at
#     /opt/novasafe-deployment/marketing/landing/.env — CI does not inject env.
#
# =============================================================================


# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Modes: development | test | staging | production
NODE_ENV=development

# Port the Vite dev server listens on.
PORT=3000


# -----------------------------------------------------------------------------
# Public URLs (browser)
# -----------------------------------------------------------------------------
# Where THIS landing project is served (used for absolute URL building, og tags,
# and as the origin baked into the generated `public/sitemap.xml` and the
# `Sitemap:` line in `public/robots.txt`).
#
# The SEO generator (`scripts/generate-seo.mjs`, auto-run by `pnpm build`)
# resolves the origin in this order:
#
#   PUBLIC_SITE_URL  >  VITE_LANDING_URL  >  https://novasafe.io
#
# Use `PUBLIC_SITE_URL` if you want to override the sitemap origin without
# changing the rest of the build (e.g. a one-off staging crawl).
VITE_LANDING_URL=http://localhost:3000

# Auth project — every CTA on this landing site lands here with an `intent=` param.
VITE_AUTH_URL=http://localhost:3001

# Authenticated app — used for "open app" links if/when a user is already signed in.
VITE_APP_URL=http://localhost:3002

# Core API — public status page data (GET /status, /status/history, /status/incidents).
VITE_API_URL=http://localhost:3125


# -----------------------------------------------------------------------------
# Build / app metadata
# -----------------------------------------------------------------------------
VITE_APP_VERSION=0.1.0
