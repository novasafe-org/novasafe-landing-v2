# pnpm config — landing-v2.
#
# minimum-release-age=0
#   Disables the 24-hour quarantine pnpm 10+ enforces by default. Our
#   lockfile is committed and generated from a trusted developer
#   environment, so freshly published transitive deps (e.g. weekly
#   Babel point releases) shouldn't block CI builds. The lockfile +
#   integrity hashes still pin every package to an exact resolved
#   version, which is the actual supply-chain control.
minimum-release-age=0
